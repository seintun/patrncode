# Skip in CI — changesets action manages changesets on release branches
if [ -n "$CI" ] || [ -n "$GITHUB_ACTIONS" ]; then
  exit 0
fi

# Get current branch name
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Don't check changesets when pushing main directly
if [ "$BRANCH" = "main" ]; then
  exit 0
fi

# Check if changesets are missing
bunx changeset status --since=origin/main >/dev/null 2>&1

if [ $? -ne 0 ]; then
  echo ""
  echo "  ❌ Missing changeset — push blocked."
  echo ""
  echo "  Run this, then push again:"
  echo "    bunx changeset add --empty   # if no version bump needed"
  echo "    bunx changeset add           # if user-facing change"
  echo ""
  exit 1
fi
